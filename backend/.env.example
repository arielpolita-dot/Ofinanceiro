# =============================================================================
# APP TEMPLATE - Backend .env Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Server Configuration
PORT=8000
NODE_ENV=development
CORS_ORIGIN={Preencher aqui}

# DATABASE (PostgreSQL)
DATABASE_URL={Preencher aqui - postgres://user:password@host:port/db}

# Audit database (centralized logs)
AUDIT_DATABASE_URL={Preencher aqui - postgres://user:password@host:port/db}

# AUTH SERVICE INTEGRATION (Authify)
AUTHIFY_URL={Preencher aqui}
AUTHIFY_FRONTEND_URL={Preencher aqui}
AUTHIFY_API_KEY={Preencher aqui}

# BILLING SERVICE INTEGRATION
BILLING_API_URL={Preencher aqui}
BILLING_FRONTEND_URL={Preencher aqui}
BILLING_API_KEY={Preencher aqui}

# ENCRYPTION
ENCRYPTION_KEY={Preencher aqui - 32 caracteres}

# FRONTEND URL
FRONTEND_URL={Preencher aqui}

# AI SERVICES (Optional)
# ANTHROPIC_API_KEY={Preencher aqui}

# META CONVERSIONS API (Optional - for ad tracking)
# META_PIXEL_ID={Preencher aqui}
# META_ACCESS_TOKEN={Preencher aqui}
