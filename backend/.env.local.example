# =============================================================================
# OFINANCEIRO - LOCAL DEVELOPMENT CONFIGURATION
# =============================================================================
PORT=8000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8001

# DATABASE (Local Docker - porta 5555)
DATABASE_URL=postgres://postgres:postgres@localhost:5555/ofinanceiro
AUDIT_DATABASE_URL=postgres://postgres:postgres@localhost:5555/ofinanceiro_audit

# AUTH SERVICE (Authify)
AUTHIFY_URL=https://api-auth.ohanax.com
AUTHIFY_FRONTEND_URL=https://auth.ohanax.com
AUTHIFY_API_KEY={Preencher aqui}

# BILLING SERVICE
BILLING_API_URL=https://api-billing.ohanax.com
BILLING_FRONTEND_URL=https://billing.ohanax.com
BILLING_API_KEY={Preencher aqui}

# ENCRYPTION - 32 caracteres para dev
ENCRYPTION_KEY=dev-encryption-key-32-chars-ok!!

# FRONTEND URL
FRONTEND_URL=http://localhost:8001
