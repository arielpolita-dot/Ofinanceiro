terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

locals {
  backend_name  = "${var.project_name}-backend"
  frontend_name = "app-${var.project_name}-frontend"
}
