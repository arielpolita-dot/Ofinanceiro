project_name = "app-template"
aws_region   = "us-east-1"
environment  = "prod"

backend_port      = 8000
backend_cpu       = "512"
backend_memory    = "1024"
cors_origins      = ["https://www.yourdomain.com"]
health_check_path = "/health"

github_repo  = "your-user/your-repo"
frontend_url = "https://www.yourdomain.com"

# Database (PostgreSQL)
database_url       = "postgres://user:password@host:port/db"
audit_database_url = "postgres://user:password@host:port/audit_db"

# Auth Service (Authify)
authify_url          = "https://p9mmmtfmim.us-east-1.awsapprunner.com"
authify_frontend_url = "https://auth.ohanax.com"
authify_api_key      = "ak_your_api_key_here"

# Billing Service
billing_api_url      = "https://fax3cspfgv.us-east-1.awsapprunner.com"
billing_frontend_url = "https://billing.ohanax.com"
billing_api_key      = "bk_your_api_key_here"

# Encryption (32 characters)
encryption_key = "your-32-char-encryption-key-here"
