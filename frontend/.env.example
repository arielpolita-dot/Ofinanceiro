# =============================================================================
# OFINANCEIRO - Frontend .env Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Backend API URL
VITE_API_URL=http://localhost:8000

# AUTH SERVICE INTEGRATION (Authify)
VITE_AUTHIFY_URL=https://api-auth.ohanax.com
VITE_AUTHIFY_FRONTEND_URL=https://auth.ohanax.com

# STORAGE PREFIX (unique per app to avoid localStorage conflicts)
VITE_STORAGE_PREFIX=ofinanceiro
